# Local Docker Compose database. Copy this file to .env.local before using database scripts.
DATABASE_URL="postgresql://readinessos:readinessos@localhost:5433/readinessos?schema=public"
# 迁移使用直连地址；生产环境中 DATABASE_URL 应指向连接池，DIRECT_URL 指向数据库直连。
DIRECT_URL="postgresql://readinessos:readinessos@localhost:5433/readinessos?schema=public"

# Required in Preview and Production. A local development default is used only when omitted.
AUTH_SECRET="replace-with-a-long-random-secret"

# Development-only Credentials provider. Set a strong value before any shared deployment.
AUTH_DEMO_EMAIL="demo@readinessos.local"
AUTH_DEMO_PASSWORD="replace-with-a-local-demo-password"
DEMO_LOGIN_ENABLED="true"

# Vercel Cron 维护接口密钥；未配置时接口保持 401，不提供开发回退。
CRON_SECRET="replace-with-a-random-secret-at-least-16-characters"

# Optional external runtimes. The deterministic local adapter remains available without them.
EVE_API_KEY=""
EVE_BASE_URL=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
SENTRY_DSN=""
