{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_DEMO_EMAIL",
        "AUTH_DEMO_PASSWORD",
        "DEMO_LOGIN_ENABLED",
        "CRON_SECRET",
        "DEEPSEEK_API_KEY",
        "EVE_RUNTIME_URL",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "SENTRY_DSN"
      ],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "DIRECT_URL"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
