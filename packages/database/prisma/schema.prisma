generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

enum ScenarioStatus {
  draft
  published
  archived
}

enum RunStatus {
  created
  running
  paused
  completed
  failed
}

enum ParticipantController {
  human
  agent
  system
}

enum EventSource {
  human
  agent
  system
  integration
}

enum AgentSessionStatus {
  active
  waiting_for_input
  completed
  failed
  terminated
}

enum ApprovalStatus {
  pending
  approved
  denied
  expired
  stale
}

enum RemediationStatus {
  open
  in_progress
  resolved
}

enum AgentRecommendationStatus {
  pending
  adopted
  modified
  rejected
  deferred
  superseded
  expired
}

enum AgentDispatchStatus {
  pending
  running
  waiting_for_input
  completed
  failed
}

enum AgentDecisionType {
  adopt
  modify
  reject
  defer
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members        Member[]
  scenarios      Scenario[]
  runs           SimulationRun[]
  runEvents      RunEvent[]
  outboxMessages OutboxMessage[]
  usageLedger    UsageLedger[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  name           String?
  isGuest        Boolean   @default(false) @map("is_guest")
  guestExpiresAt DateTime? @map("guest_expires_at")
  guestTokenHash String?   @map("guest_token_hash")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  memberships Member[]
  createdRuns SimulationRun[] @relation("RunCreator")

  @@index([isGuest, guestExpiresAt])
  @@map("users")
}

model Member {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(member)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, organizationId])
  @@map("members")
}

model Scenario {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  key            String
  name           String
  description    String
  status         ScenarioStatus @default(draft)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     ScenarioVersion[]

  @@unique([organizationId, key])
  @@index([organizationId, status])
  @@map("scenarios")
}

model ScenarioVersion {
  id          String    @id @default(uuid()) @db.Uuid
  scenarioId  String    @map("scenario_id") @db.Uuid
  version     Int
  config      Json
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  scenario Scenario        @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  runs     SimulationRun[]

  @@unique([scenarioId, version])
  @@map("scenario_versions")
}

model SimulationRun {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  scenarioVersionId    String    @map("scenario_version_id") @db.Uuid
  parentRunId          String?   @map("parent_run_id") @db.Uuid
  branchFromSequence   Int?      @map("branch_from_sequence")
  status               RunStatus @default(created)
  version              Int       @default(0)
  seed                 Int
  virtualTime          Int       @default(0) @map("virtual_time")
  latestSequence       Int       @default(0) @map("latest_sequence")
  agentActivitySequence Int      @default(0) @map("agent_activity_sequence")
  startedAt            DateTime? @map("started_at")
  completedAt          DateTime? @map("completed_at")
  expiresAt            DateTime? @map("expires_at")
  createdById          String    @map("created_by") @db.Uuid
  createIdempotencyKey String?   @map("create_idempotency_key")
  schedulerGeneration  Int       @default(0) @map("scheduler_generation")
  nextTickIndex        Int       @default(0) @map("next_tick_index")
  tickIntervalSeconds  Int       @default(15) @map("tick_interval_seconds")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scenarioVersion  ScenarioVersion        @relation(fields: [scenarioVersionId], references: [id], onDelete: Restrict)
  parentRun        SimulationRun?         @relation("RunBranches", fields: [parentRunId], references: [id], onDelete: Restrict)
  branches         SimulationRun[]        @relation("RunBranches")
  createdBy        User                   @relation("RunCreator", fields: [createdById], references: [id], onDelete: Restrict)
  participants     RunParticipant[]
  events           RunEvent[]
  snapshots        StateSnapshot[]
  checkpoints      Checkpoint[]
  overview         RunOverviewProjection?
  timeline         TimelineProjection[]
  outboxMessages   OutboxMessage[]
  agentTraces      AgentTrace[]
  usageLedger      UsageLedger[]
  scheduleLease    RunScheduleLease?
  approvals        Approval[]
  decisions        Decision[]
  evidences        Evidence[]
  evaluations      Evaluation[]
  remediationItems RemediationItem[]
  agentRecommendations AgentRecommendation[]
  agentDispatches      AgentDispatch[]
  agentQuestions       AgentQuestion[]
  agentActivities      AgentActivity[]

  @@unique([organizationId, createdById, createIdempotencyKey])
  @@index([organizationId, status, createdAt])
  @@index([expiresAt])
  @@index([parentRunId, branchFromSequence])
  @@map("simulation_runs")
}

model RunScheduleLease {
  runId          String   @id @map("run_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  generation     Int
  holderId       String   @map("holder_id") @db.Uuid
  heartbeatAt    DateTime @map("heartbeat_at")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  run SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([organizationId, expiresAt])
  @@index([expiresAt])
  @@map("run_schedule_leases")
}

model RunParticipant {
  id              String                @id @default(uuid()) @db.Uuid
  runId           String                @map("run_id") @db.Uuid
  key             String
  displayName     String                @map("display_name")
  controller      ParticipantController
  capabilities    Json                  @default("[]")
  permissions     Json                  @default("[]")
  objectives      Json                  @default("[]")
  knowledgeScopes Json                  @default("[]") @map("knowledge_scopes")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  run               SimulationRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  projection        ParticipantProjection?
  agentSessionLinks AgentSessionLink[]
  agentTraces                 AgentTrace[]
  usageLedger                 UsageLedger[]
  authoredAgentRecommendations AgentRecommendation[] @relation("AgentRecommendationAdvisor")
  targetedAgentRecommendations AgentRecommendation[] @relation("AgentRecommendationTarget")
  agentDispatches             AgentDispatch[]

  @@unique([runId, key])
  @@index([runId, controller])
  @@map("run_participants")
}

model RunEvent {
  id             String      @id @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  runId          String      @map("run_id") @db.Uuid
  sequence       Int
  type           String
  version        Int
  source         EventSource
  participantId  String?     @map("participant_id") @db.Uuid
  simulatedAt    DateTime    @map("simulated_at")
  recordedAt     DateTime    @map("recorded_at")
  causationId    String?     @map("causation_id") @db.Uuid
  correlationId  String?     @map("correlation_id") @db.Uuid
  idempotencyKey String      @map("idempotency_key")
  payload        Json

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run          SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@unique([runId, idempotencyKey])
  @@index([organizationId, recordedAt(sort: Desc)])
  @@index([runId, type, sequence])
  @@index([runId, participantId, sequence])
  @@map("run_events")
}

model StateSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  runId         String   @map("run_id") @db.Uuid
  sequence      Int
  schemaVersion Int      @default(1) @map("schema_version")
  state         Json
  checksum      String
  createdAt     DateTime @default(now()) @map("created_at")

  run SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId, sequence(sort: Desc)])
  @@map("state_snapshots")
}

model Checkpoint {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @map("run_id") @db.Uuid
  sequence  Int
  label     String
  createdAt DateTime @default(now()) @map("created_at")

  run SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId, createdAt])
  @@map("checkpoints")
}

model Approval {
  id                   String         @id @db.Uuid
  runId                String         @map("run_id") @db.Uuid
  actionType           String         @map("action_type")
  participantId        String         @map("participant_id") @db.Uuid
  requestedByCommandId String         @map("requested_by_command_id") @db.Uuid
  requestedSequence    Int            @map("requested_sequence")
  parameters           Json           @default("{}")
  status               ApprovalStatus @default(pending)
  requestedAt          DateTime       @map("requested_at")
  expiresAt            DateTime       @map("expires_at")
  resolvedAt           DateTime?      @map("resolved_at")
  resolvedById         String?        @map("resolved_by_id") @db.Uuid
  resolutionSequence   Int?           @map("resolution_sequence")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  run       SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  decisions Decision[]
  evidences Evidence[]

  @@index([runId, status, expiresAt])
  @@index([runId, requestedSequence])
  @@map("approvals")
}

model Decision {
  id                   String             @id @default(uuid()) @db.Uuid
  runId                String             @map("run_id") @db.Uuid
  approvalId           String?            @unique @map("approval_id") @db.Uuid
  recommendationId     String?            @map("recommendation_id") @db.Uuid
  sequence             Int?
  decision             String
  agentDecisionType    AgentDecisionType? @map("agent_decision_type")
  actorId              String?            @map("actor_id") @db.Uuid
  actorName            String?            @map("actor_name")
  rationale            String?
  modifiedActionType   String?            @map("modified_action_type")
  modifiedParameters   Json?              @map("modified_parameters")
  kernelCommandId      String?            @map("kernel_command_id") @db.Uuid
  executionSequence    Int?               @map("execution_sequence")
  createdAt            DateTime           @default(now()) @map("created_at")

  run            SimulationRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  approval       Approval?            @relation(fields: [approvalId], references: [id], onDelete: SetNull)
  recommendation AgentRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)

  @@index([recommendationId])
  @@index([runId, sequence])
  @@index([runId, kernelCommandId])
  @@index([runId, createdAt])
  @@map("decisions")
}

model AgentRecommendation {
  id                   String                    @id @default(uuid()) @db.Uuid
  organizationId       String                    @map("organization_id") @db.Uuid
  runId                String                    @map("run_id") @db.Uuid
  advisorParticipantId String                    @map("advisor_participant_id") @db.Uuid
  targetParticipantId  String                    @map("target_participant_id") @db.Uuid
  actionType           String                    @map("action_type")
  parameters           Json                      @default("{}")
  rationale            String
  evidenceRefs         Json                      @default("[]") @map("evidence_refs")
  confidence           Float
  triggerEventTypes    Json                      @default("[]") @map("trigger_event_types")
  triggerSequences     Json                      @default("[]") @map("trigger_sequences")
  observationHash      String                    @map("observation_hash")
  baseRunVersion       Int                       @map("base_run_version")
  baseVirtualTime      Int                       @map("base_virtual_time")
  expiresAtVirtualTime Int                       @map("expires_at_virtual_time")
  eveSessionId         String?                   @map("eve_session_id")
  eveTraceIdentity     String?                   @map("eve_trace_identity")
  status               AgentRecommendationStatus @default(pending)
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  run          SimulationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  advisor      RunParticipant @relation("AgentRecommendationAdvisor", fields: [advisorParticipantId], references: [id], onDelete: Cascade)
  target       RunParticipant @relation("AgentRecommendationTarget", fields: [targetParticipantId], references: [id], onDelete: Cascade)
  questions    AgentQuestion[]
  decisions    Decision[]
  activities   AgentActivity[]

  @@index([runId, status, createdAt(sort: Desc)])
  @@index([advisorParticipantId, status])
  @@map("agent_recommendations")
}

model AgentDispatch {
  id                   String              @id @default(uuid()) @db.Uuid
  organizationId       String              @map("organization_id") @db.Uuid
  runId                String              @map("run_id") @db.Uuid
  advisorParticipantId String              @map("advisor_participant_id") @db.Uuid
  status               AgentDispatchStatus @default(pending)
  activeKey            String?             @unique @map("active_key")
  requestKind          String              @default("automatic") @map("request_kind")
  triggerEventTypes    Json                @default("[]") @map("trigger_event_types")
  triggerSequences     Json                @default("[]") @map("trigger_sequences")
  baseRunVersion       Int                 @map("base_run_version")
  observationHash      String?             @map("observation_hash")
  attempts             Int                 @default(0)
  nextAttemptAt        DateTime            @default(now()) @map("next_attempt_at")
  lockedAt             DateTime?           @map("locked_at")
  lastError            String?             @map("last_error")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  run        SimulationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  advisor    RunParticipant @relation(fields: [advisorParticipantId], references: [id], onDelete: Cascade)
  questions  AgentQuestion[]
  activities AgentActivity[]

  @@index([runId, status, nextAttemptAt])
  @@index([advisorParticipantId, status])
  @@map("agent_dispatches")
}

model AgentQuestion {
  id               String   @id @default(uuid()) @db.Uuid
  runId            String   @map("run_id") @db.Uuid
  dispatchId       String   @map("dispatch_id") @db.Uuid
  recommendationId String?  @map("recommendation_id") @db.Uuid
  requestId        String   @unique @map("request_id")
  prompt           String
  options          Json     @default("[]")
  allowFreeform    Boolean  @default(false) @map("allow_freeform")
  answer           Json?
  answeredById     String?  @map("answered_by_id") @db.Uuid
  answeredAt       DateTime? @map("answered_at")
  createdAt        DateTime @default(now()) @map("created_at")

  run            SimulationRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  dispatch       AgentDispatch        @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  recommendation AgentRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)

  @@index([runId, answeredAt])
  @@map("agent_questions")
}

model AgentActivity {
  id               String   @id @default(uuid()) @db.Uuid
  runId            String   @map("run_id") @db.Uuid
  sequence         Int
  type             String
  dispatchId       String?  @map("dispatch_id") @db.Uuid
  recommendationId String?  @map("recommendation_id") @db.Uuid
  data             Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  run            SimulationRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  dispatch       AgentDispatch?       @relation(fields: [dispatchId], references: [id], onDelete: SetNull)
  recommendation AgentRecommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)

  @@unique([runId, sequence])
  @@index([runId, createdAt])
  @@map("agent_activities")
}

model Evaluation {
  id           String   @id @default(uuid()) @db.Uuid
  runId        String   @map("run_id") @db.Uuid
  evaluatorKey String   @map("evaluator_key")
  sequence     Int
  score        Float
  summary      String
  createdAt    DateTime @default(now()) @map("created_at")

  run              SimulationRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  evidences        Evidence[]
  remediationItems RemediationItem[]

  @@unique([runId, evaluatorKey, sequence])
  @@index([runId, sequence])
  @@map("evaluations")
}

model Evidence {
  id           String   @id @default(uuid()) @db.Uuid
  runId        String   @map("run_id") @db.Uuid
  evaluationId String?  @map("evaluation_id") @db.Uuid
  approvalId   String?  @map("approval_id") @db.Uuid
  sequence     Int
  eventType    String   @map("event_type")
  label        String
  data         Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  run        SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  evaluation Evaluation?   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  approval   Approval?     @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, sequence, eventType])
  @@unique([approvalId, sequence, eventType])
  @@index([runId, sequence])
  @@index([approvalId])
  @@map("evidences")
}

model RemediationItem {
  id           String            @id @default(uuid()) @db.Uuid
  runId        String            @map("run_id") @db.Uuid
  evaluationId String?           @map("evaluation_id") @db.Uuid
  title        String
  description  String
  status       RemediationStatus @default(open)
  ownerId      String?           @map("owner_id") @db.Uuid
  dueAt        DateTime?         @map("due_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  run        SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  evaluation Evaluation?   @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@index([runId, status, updatedAt(sort: Desc)])
  @@map("remediation_items")
}

model AgentSessionLink {
  id                String             @id @default(uuid()) @db.Uuid
  runParticipantId  String             @map("run_participant_id") @db.Uuid
  provider          String
  agentKey          String             @map("agent_key")
  sessionId         String?            @map("session_id")
  continuationToken String?            @map("continuation_token")
  streamIndex       Int                @default(0) @map("stream_index")
  status            AgentSessionStatus @default(active)
  metadata          Json               @default("{}")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  participant RunParticipant @relation(fields: [runParticipantId], references: [id], onDelete: Cascade)

  @@unique([runParticipantId, provider, agentKey])
  @@index([sessionId])
  @@map("agent_session_links")
}

model AgentTrace {
  id               String   @id @default(uuid()) @db.Uuid
  runId            String   @map("run_id") @db.Uuid
  runParticipantId String?  @map("run_participant_id") @db.Uuid
  sessionId        String?  @map("session_id")
  streamIndex      Int?     @map("stream_index")
  traceIdentity    String   @unique @map("trace_identity")
  eventType        String   @map("event_type")
  payload          Json
  recordedAt       DateTime @default(now()) @map("recorded_at")

  run         SimulationRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  participant RunParticipant? @relation(fields: [runParticipantId], references: [id], onDelete: SetNull)

  @@index([runId, recordedAt, id])
  @@index([sessionId, streamIndex])
  @@map("agent_traces")
}

model RunOverviewProjection {
  runId          String    @id @map("run_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  status         RunStatus
  latestSequence Int       @map("latest_sequence")
  virtualTime    Int       @map("virtual_time")
  data           Json
  updatedAt      DateTime  @updatedAt @map("updated_at")

  run SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@map("run_overview_projection")
}

model ParticipantProjection {
  runParticipantId String   @id @map("run_participant_id") @db.Uuid
  runId            String   @map("run_id") @db.Uuid
  status           String
  data             Json
  updatedAt        DateTime @updatedAt @map("updated_at")

  participant RunParticipant @relation(fields: [runParticipantId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@map("participant_projection")
}

model TimelineProjection {
  id        String      @id @default(uuid()) @db.Uuid
  runId     String      @map("run_id") @db.Uuid
  sequence  Int
  eventId   String      @map("event_id") @db.Uuid
  type      String
  source    EventSource
  data      Json
  createdAt DateTime    @default(now()) @map("created_at")

  run SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@unique([eventId])
  @@index([runId, createdAt])
  @@map("timeline_projection")
}

model OutboxMessage {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  runId          String?   @map("run_id") @db.Uuid
  topic          String
  payload        Json
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at")
  lockedAt       DateTime? @map("locked_at")
  publishedAt    DateTime? @map("published_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run          SimulationRun? @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([publishedAt, nextAttemptAt])
  @@index([runId, createdAt])
  @@map("outbox_messages")
}

model UsageLedger {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  runId            String?  @map("run_id") @db.Uuid
  runParticipantId String?  @map("run_participant_id") @db.Uuid
  category         String
  quantity         Int
  unit             String
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run          SimulationRun?  @relation(fields: [runId], references: [id], onDelete: Cascade)
  participant  RunParticipant? @relation(fields: [runParticipantId], references: [id], onDelete: SetNull)

  @@index([organizationId, category, createdAt])
  @@index([runId, createdAt])
  @@map("usage_ledger")
}

/**
 * 固定窗口限流只保存 HMAC 后的来源标识，避免将 IP 或浏览器标识作为明文
 * 个人数据持久化。每个 scope 的窗口由应用层规范化到统一起始时间。
 */
model RequestRateLimit {
  id             String   @id @default(uuid()) @db.Uuid
  scope          String
  keyHash        String   @map("key_hash")
  windowStartsAt DateTime @map("window_starts_at")
  count          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

